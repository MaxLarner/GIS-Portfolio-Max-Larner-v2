---
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="navbar">
  <div class="nav-inner container">
    <a href="/" class="nav-brand">
      <span class="brand-initials">ML</span>
      <span class="brand-name">Max Larner</span>
    </a>

    <nav class="nav-links">
      {links.map(link => {
        const isActive = link.href === '/'
          ? pathname === '/'
          : pathname.startsWith(link.href);
        return (
          <a href={link.href} class:list={['nav-link', { active: isActive }]}>
            {link.label}
          </a>
        );
      })}
    </nav>

    <a
      href="https://github.com/MaxLarner/gis-portfolio-max-larner"
      target="_blank"
      rel="noopener"
      class="nav-github"
      aria-label="GitHub"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482
          0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462
          -.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832
          .092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683
          -.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59
          0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699
          1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336
          -.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
      </svg>
    </a>

    <!-- Mobile hamburger -->
    <button class="nav-toggle" aria-label="Toggle menu" onclick="document.querySelector('.nav-links').classList.toggle('open')">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-h);
    background: rgba(8, 13, 24, 0.85);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-initials {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: var(--accent);
    color: var(--bg);
    font-weight: 800;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: -0.02em;
  }

  .brand-name {
    font-weight: 700;
    font-size: 1rem;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-link {
    padding: 0.45rem 0.85rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-2);
    transition: color 0.15s ease, background 0.15s ease;
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--bg-2);
  }

  .nav-link.active {
    color: var(--accent);
    background: var(--accent-dim);
  }

  .nav-github {
    color: var(--text-3);
    display: flex;
    align-items: center;
    transition: color 0.15s ease;
    margin-left: 0.5rem;
  }

  .nav-github:hover { color: var(--text); }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: 0.5rem;
  }

  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-2);
    border-radius: 2px;
    transition: background 0.15s;
  }

  @media (max-width: 640px) {
    .nav-toggle { display: flex; }

    .nav-links {
      display: none;
      position: absolute;
      top: var(--nav-h);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: var(--bg-1);
      border-bottom: 1px solid var(--border);
      padding: 0.75rem 1.5rem 1.25rem;
      gap: 0.25rem;
    }

    .nav-links.open { display: flex; }

    .nav-link { padding: 0.65rem 0.75rem; }
  }
</style>
