<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-copy">© {new Date().getFullYear()} Max Larner</p>
    <div class="footer-links">
      <a href="https://github.com/MaxLarner" target="_blank" rel="noopener">GitHub</a>
      <a href="https://linkedin.com/in/max-larner-b53610208" target="_blank" rel="noopener">LinkedIn</a>
      <a href="mailto:max.larner123@gmail.com">max.larner123@gmail.com</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 0;
    margin-top: 5rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 0.875rem;
    color: var(--text-3);
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--text-3);
    transition: color 0.15s ease;
  }

  .footer-links a:hover { color: var(--accent); }
</style>
