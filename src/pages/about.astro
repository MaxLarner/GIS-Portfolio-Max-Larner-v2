---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const skills = [
  {
    category: "Geospatial Programming",
    items: ["Python", "GeoPandas", "Shapely", "Rasterio", "PyProj", "Fiona", "scikit-image", "SciPy"],
  },
  {
    category: "GIS Platforms",
    items: ["ArcGIS Pro", "QGIS", "ArcPy"],
  },
  {
    category: "Data & Analysis",
    items: ["NumPy", "Pandas", "Matplotlib", "Spatial Indexing (R-tree)", "MCDA", "Landscape Ecology Metrics"],
  },
  {
    category: "Development",
    items: ["Git", "GitHub", "Quarto", "Python OOP", "Algorithm Design", "Reproducible Research"],
  },
];
---
<BaseLayout title="About" description="About Max Larner — geography graduate, GIS analyst, conservation technologist.">
  <Navbar slot="nav" />

  <!-- Hero strip -->
  <section class="about-hero">
    <div class="container">
      <span class="section-label">About Me</span>
      <h1>Geography graduate &<br />spatial thinker.</h1>
    </div>
  </section>

  <div class="container about-body">
    <!-- Bio -->
    <section class="bio-section">
      <div class="bio-text prose">
        <h2>Background</h2>
        <p>
          I'm a 1st-class Geography BSc graduate from the University of Manchester, looking for
          opportunities in GIS-informed consultation or technical roles. My interests span planning,
          landscape ecology and biodiversity net gain (BNG), and sustainable development —
          opportunities aligned with these goals are always welcome.
        </p>
        <p>
          My dissertation — <em>Please Marten the Gap</em> — developed a Python-based spatial
          prioritisation framework for red squirrel conservation, combining species interaction
          modelling with multi-criteria decision analysis to guide reserve selection under pine
          marten recolonisation scenarios in Cumbria. It received a grade of 78.
        </p>
        <p>
          Outside of GIS, I'm drawn to the intersection of computational methods and real-world
          conservation: how models can inform better land management decisions, how stakeholder
          engagement shapes conservation outcomes, and how transparent, open-source tools can build
          trust between scientists and practitioners.
        </p>

        <h2>Education</h2>
        <div class="edu-card">
          <div class="edu-degree">BSc Geography — 1st Class Honours</div>
          <div class="edu-institution">University of Manchester</div>
          <div class="edu-years">2022 – 2025</div>
        </div>

        <h2>Contact</h2>
        <p>I'm open to roles in GIS, conservation technology, spatial planning, and related fields.
          Get in touch via any of the channels below.</p>
        <div class="contact-links">
          <a href="mailto:max.larner123@gmail.com" class="contact-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            max.larner123@gmail.com
          </a>
          <a href="https://linkedin.com/in/max-larner-b53610208" target="_blank" rel="noopener" class="contact-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
            LinkedIn
          </a>
          <a href="https://github.com/MaxLarner" target="_blank" rel="noopener" class="contact-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482
                0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462
                -.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832
                .092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683
                -.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59
                0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699
                1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336
                -.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>

      <!-- Skills sidebar -->
      <aside class="skills-sidebar">
        <h2 class="skills-heading">Skills</h2>
        <div class="skills-groups">
          {skills.map(group => (
            <div class="skill-group">
              <h3 class="skill-cat">{group.category}</h3>
              <div class="skill-tags">
                {group.items.map(item => <span class="tag">{item}</span>)}
              </div>
            </div>
          ))}
        </div>
      </aside>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .about-hero {
    padding: calc(var(--nav-h) + 4rem) 0 3.5rem;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(to bottom, var(--bg-1), var(--bg));
  }

  .about-hero h1 {
    margin-top: 0.5rem;
    line-height: 1.15;
  }

  .about-body {
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .bio-section {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 5rem;
    align-items: start;
  }

  /* Education card */
  .edu-card {
    background: var(--bg-1);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .edu-degree {
    font-weight: 700;
    font-size: 1rem;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .edu-institution {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 0.2rem;
  }

  .edu-years {
    font-size: 0.85rem;
    color: var(--text-3);
  }

  /* Contact links */
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-2);
    font-size: 0.95rem;
    transition: color 0.15s ease;
  }

  .contact-link:hover { color: var(--accent); }

  /* Skills sidebar */
  .skills-sidebar {
    position: sticky;
    top: calc(var(--nav-h) + 2rem);
  }

  .skills-heading {
    font-size: 1.1rem;
    color: var(--text);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .skills-groups {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-cat {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 0.6rem;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  @media (max-width: 900px) {
    .bio-section {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .skills-sidebar { position: static; }
  }
</style>
