---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const projects = [
  {
    title: "Dissertation — Spatial Prioritisation for Red Squirrel Conservation",
    slug: "dissertation",
    grade: 78,
    module: "Dissertation",
    year: 2025,
    description: "Developed a Python-based spatial prioritisation framework to identify optimal red squirrel strongholds under pine marten recolonisation in Cumbria. Combines MCDA, landscape ecology metrics, and suppression modelling.",
    image: "/images/dissertation/algorithm_strongholds.png",
    tags: ["Python", "GeoPandas", "ArcGIS Pro", "MCDA", "Landscape Ecology"],
  },
  {
    title: "World's Shortest Border Algorithm",
    slug: "assignment1",
    grade: 83,
    module: "GIS Programming",
    year: 2025,
    description: "Custom algorithm using spatial indexing (R-tree) and WGS84 geodesic geometry to efficiently identify the world's shortest international land border — Italy and Vatican City.",
    image: "/images/assignment1/shortest_border.png",
    tags: ["Python", "GeoPandas", "PyProj", "R-tree", "Matplotlib"],
  },
  {
    title: "Weighted Spatial Redistribution Algorithm",
    slug: "assignment2",
    grade: 82,
    module: "GIS Programming",
    year: 2025,
    description: "Implementation of Jonny Huck's (2015) weighted redistribution algorithm to resolve the false hotspot problem in spatially ambiguous, passively geocoded Twitter data across Greater Manchester.",
    image: "/images/assignment2/redistribution_grid.png",
    tags: ["Python", "GeoPandas", "Rasterio", "NumPy", "skimage"],
  },
];
---
<BaseLayout title="Projects" description="GIS projects by Max Larner — spatial analysis, conservation, and Python geospatial workflows.">
  <Navbar slot="nav" />

  <section class="page-hero">
    <div class="container">
      <span class="section-label">Portfolio</span>
      <h1>Projects</h1>
      <p class="page-sub">
        A selection of geospatial projects from university, each written up as a full case study
        with methodology, results, and code.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="list-cards">
        {projects.map((p, i) => (
          <a href={`/projects/${p.slug}`} class="list-card" style={`animation-delay: ${i * 0.1}s`}>
            <div class="lc-img">
              <img src={p.image} alt={p.title} loading="lazy" />
            </div>
            <div class="lc-body">
              <div class="lc-meta">
                <span class="grade-badge">{p.grade} / 100</span>
                <span class="tag">{p.module}</span>
                <span class="tag">{p.year}</span>
              </div>
              <h2 class="lc-title">{p.title}</h2>
              <p class="lc-desc">{p.description}</p>
              <div class="lc-tags">
                {p.tags.map(t => <span class="tag">{t}</span>)}
              </div>
              <span class="link-arrow">Read case study <span>→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-hero {
    padding: calc(var(--nav-h) + 3.5rem) 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .page-hero h1 { margin: 0.5rem 0 1rem; }

  .page-sub {
    font-size: 1.05rem;
    max-width: 56ch;
    color: var(--text-2);
    margin: 0;
  }

  .list-cards {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .list-card {
    display: grid;
    grid-template-columns: 320px 1fr;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-1);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    animation: fadeUp 0.6s ease both;
    cursor: pointer;
  }

  .list-card:hover {
    border-color: var(--border-hi);
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .lc-img {
    overflow: hidden;
    background: var(--bg-2);
    aspect-ratio: unset;
  }

  .lc-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .list-card:hover .lc-img img { transform: scale(1.04); }

  .lc-body {
    padding: 2rem 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .lc-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .lc-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    margin: 0;
  }

  .lc-desc {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .lc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  @media (max-width: 800px) {
    .list-card { grid-template-columns: 1fr; }
    .lc-img { aspect-ratio: 16 / 8; }
    .lc-body { padding: 1.5rem; }
  }
</style>
