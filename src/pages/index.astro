---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    title: "Dissertation — Spatial Prioritisation for Red Squirrel Conservation",
    short: "Dissertation",
    slug: "dissertation",
    grade: 78,
    description: "Developed a Python-based spatial prioritisation framework to identify optimal red squirrel strongholds under pine marten recolonisation in Cumbria, combining MCDA with landscape ecology.",
    image: "/images/dissertation/algorithm_strongholds.png",
    tags: ["Python", "GeoPandas", "ArcGIS Pro", "MCDA"],
  },
  {
    title: "World's Shortest Border Algorithm",
    short: "Shortest Border",
    slug: "assignment1",
    grade: 83,
    description: "Custom algorithm using spatial indexing and geodesic geometry to identify the world's shortest international land border with high computational efficiency.",
    image: "/images/assignment1/shortest_border.png",
    tags: ["Python", "GeoPandas", "PyProj", "R-tree"],
  },
  {
    title: "Weighted Spatial Redistribution Algorithm",
    short: "Redistribution",
    slug: "assignment2",
    grade: 82,
    description: "Implementation of Jonny Huck's (2015) weighted redistribution algorithm to resolve spatial ambiguity in passively geocoded Twitter data across Greater Manchester.",
    image: "/images/assignment2/redistribution_grid.png",
    tags: ["Python", "GeoPandas", "Rasterio", "NumPy"],
  },
];

const tools = [
  "Python", "GeoPandas", "Rasterio", "PyProj",
  "ArcGIS Pro", "QGIS", "NumPy", "Matplotlib",
  "Spatial Indexing", "MCDA", "Landscape Ecology", "Git",
];
---
<BaseLayout title="Portfolio">
  <Navbar slot="nav" />

  <!-- ── HERO ────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content container">
      <span class="section-label fade-up">GIS · Conservation · Spatial Analysis</span>
      <h1 class="hero-title fade-up-1">Max Larner</h1>
      <p class="hero-sub fade-up-2">
        Geography graduate building spatial tools for environmental decision-making.<br />
        Specialising in conservation GIS, Python workflows, and landscape ecology.
      </p>
      <div class="hero-actions fade-up-3">
        <a href="/projects" class="btn btn-primary">View Projects</a>
        <a href="/about" class="btn btn-ghost">About Me</a>
      </div>
    </div>
    <div class="hero-scroll fade-up-4" aria-hidden="true">
      <span>Scroll</span>
      <div class="scroll-indicator"></div>
    </div>
  </section>

  <!-- ── FEATURED PROJECTS ─────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-label">Work</span>
          <h2>Featured Projects</h2>
        </div>
        <a href="/projects" class="link-arrow">View all <span>→</span></a>
      </div>

      <div class="projects-grid">
        {projects.map((p, i) => (
          <a href={`/projects/${p.slug}`} class="project-card" style={`animation-delay: ${i * 0.1}s`}>
            <div class="card-img-wrap">
              <img src={p.image} alt={p.title} loading="lazy" />
              <span class="grade-badge">{p.grade}</span>
            </div>
            <div class="card-body">
              <div class="card-tags">
                {p.tags.map(t => <span class="tag">{t}</span>)}
              </div>
              <h3 class="card-title">{p.short}</h3>
              <p class="card-desc">{p.description}</p>
              <span class="card-cta">Read more <span class="arrow">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TOOLS ─────────────────────────────────── -->
  <section class="tools-section">
    <div class="container">
      <span class="section-label">Stack</span>
      <h2 class="tools-heading">Tools & Technologies</h2>
      <div class="tools-grid">
        {tools.map(t => <span class="tool-chip">{t}</span>)}
      </div>
    </div>
  </section>

  <!-- ── ABOUT TEASER ───────────────────────────── -->
  <section class="section about-teaser">
    <div class="container about-inner">
      <div class="about-text">
        <span class="section-label">About</span>
        <h2>Geography graduate,<br />spatial thinker.</h2>
        <p>
          I'm a 1st-class Geography BSc graduate from the University of Manchester,
          looking for opportunities in GIS-informed consultation or technical roles.
          My interests span planning, landscape ecology and biodiversity net gain (BNG),
          and sustainable development.
        </p>
        <div class="about-actions">
          <a href="/about" class="btn btn-outline">Full Bio</a>
          <a href="https://linkedin.com/in/max-larner-b53610208" target="_blank" rel="noopener" class="link-arrow">
            LinkedIn <span>→</span>
          </a>
        </div>
      </div>
      <div class="about-stats">
        <div class="stat">
          <span class="stat-num">3</span>
          <span class="stat-label">GIS Projects</span>
        </div>
        <div class="stat">
          <span class="stat-num">1st</span>
          <span class="stat-label">Class Honours</span>
        </div>
        <div class="stat">
          <span class="stat-num">81</span>
          <span class="stat-label">Average Grade</span>
        </div>
        <div class="stat">
          <span class="stat-num">2k+</span>
          <span class="stat-label">Lines of Python</span>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ── Hero ───────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: var(--nav-h);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to bottom, rgba(8,13,24,0.7) 0%, rgba(8,13,24,0.85) 60%, rgba(8,13,24,1) 100%),
      url('/images/topographic_1.png');
    background-size: cover;
    background-position: center;
    animation: slowZoom 20s ease-in-out infinite alternate;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 4rem;
    padding-bottom: 6rem;
    max-width: 780px;
  }

  .hero-title {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.0;
    margin: 0.5rem 0 1.25rem;
    background: linear-gradient(135deg, #f1f5f9 0%, #94a3b8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-2);
    max-width: 54ch;
    margin-bottom: 2.25rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 1;
    color: var(--text-3);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .scroll-indicator {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--border-hi), transparent);
    animation: scrollBounce 1.8s ease-in-out infinite;
  }

  /* ── Projects grid ───────────────────── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    background: var(--bg-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    animation: fadeUp 0.6s ease both;
    cursor: pointer;
  }

  .project-card:hover {
    border-color: var(--border-hi);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .card-img-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-2);
  }

  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .project-card:hover .card-img-wrap img {
    transform: scale(1.04);
  }

  .card-img-wrap .grade-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
  }

  .card-body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .card-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    margin-top: 0.25rem;
  }

  .card-cta .arrow {
    transition: transform 0.2s ease;
  }

  .project-card:hover .card-cta .arrow {
    transform: translateX(4px);
  }

  /* ── Tools ───────────────────────────── */
  .tools-section {
    padding: 4rem 0;
    background: var(--bg-1);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .tools-heading {
    margin-bottom: 1.75rem;
    font-size: 1.5rem;
  }

  .tools-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .tool-chip {
    padding: 0.45rem 1rem;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    background: var(--bg-3);
    color: var(--text-2);
    border: 1px solid var(--border);
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .tool-chip:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── About teaser ────────────────────── */
  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .about-text h2 {
    margin: 0.5rem 0 1rem;
    line-height: 1.2;
  }

  .about-text p {
    margin-bottom: 1.75rem;
    font-size: 1rem;
  }

  .about-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .stat {
    background: var(--bg-1);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: border-color 0.15s ease;
  }

  .stat:hover { border-color: var(--accent-dim); }

  .stat-num {
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-3);
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .about-inner { grid-template-columns: 1fr; gap: 3rem; }
  }

  @media (max-width: 640px) {
    .hero-content { padding-bottom: 4rem; }
    .hero-scroll { display: none; }
  }
</style>
